# Streamlit ネイティブ OIDC（Google ログイン）設定テンプレート
#
# 本番（Fly.io）では web_main.py が環境変数からこのファイルを自動生成するため、
# サーバー上に手で置く必要はない（GOOGLE_CLIENT_ID 等を Fly secrets に設定するだけ）。
#
# ローカルで Google ログインを試すときだけ、このファイルを
#   .streamlit/secrets.toml
# にコピーして値を埋める（このファイルは .gitignore 済み）。

[auth]
# OAuth コールバック URL。末尾は必ず /oauth2callback。
# ローカル: http://localhost:8501/oauth2callback
# 本番:     https://prediction-market-analysis.fly.dev/oauth2callback
redirect_uri = "http://localhost:8501/oauth2callback"

# セッション cookie 署名用のランダム文字列（例: python -c "import secrets;print(secrets.token_urlsafe(32))"）
cookie_secret = "CHANGE_ME_random_long_string"

[auth.google]
client_id = "xxxxxxxx.apps.googleusercontent.com"
client_secret = "GOCSPX-xxxxxxxx"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"
