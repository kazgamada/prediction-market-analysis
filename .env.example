# Polygon RPC (Alchemy / QuickNode / Infura recommended)
POLYGON_RPC_HTTP=
POLYGON_RPC_WS=

# Database (psycopg3 form; auto-normalized from `postgres://` too)
DATABASE_URL=postgresql+psycopg://copytrader:copytrader@localhost:5432/copytrader

# Web UI password (session-persistent gate). If set, the UI requires this
# password once per browser session. If empty the gate is OPEN — only OK for
# local dev; ALWAYS set it for any public deployment (protects kill switch /
# manual order / watchlist).
WEB_PASSWORD=changeme

# Indexer window in days (default 30, max 90)
INDEXER_WINDOW_DAYS=30

# Optional: Telegram notifier
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# AI / OpenRouter（管理者メニュー > AI設定）
# API キーは管理者画面（app_settings テーブル）から入力するのが本筋。下記 env は
# DB 未設定時のフォールバック。解決順: DB → OPENROUTER_API_KEY → ANTHROPIC_API_KEY。
# クライアントに公開しないこと（サーバ側のみで参照）。
OPENROUTER_API_KEY=        # https://openrouter.ai/keys で取得
OPENROUTER_MODEL=          # 指定すると DB の選択モデルより強制優先（例: anthropic/claude-3.5-sonnet）
ANTHROPIC_API_KEY=         # 最終フォールバック（Anthropic 直叩き）
USD_JPY_RATE=155.0         # コスト円換算の為替レート

# Live execution (Phase 1+). All optional until execution_enabled=true.
# CLOB API credentials (Polymarket) — without these the executor dry-runs.
CLOB_API_KEY=
CLOB_API_SECRET=
CLOB_API_PASSPHRASE=
CLOB_HOST=
# Signing key + wallet. TRADER_PRIVATE_KEY must stay secret (never commit).
TRADER_PRIVATE_KEY=
# TRADER_ADDRESS is read by the balance_refresh job to feed the risk USDC/MATIC
# floors. USDC_CONTRACT defaults to Polygon bridged USDC.e; USDC_DECIMALS to 6.
TRADER_ADDRESS=
USDC_CONTRACT=
USDC_DECIMALS=6

# Optional: build metadata for diagnostics page
GIT_SHA=
BUILD_TIME=
